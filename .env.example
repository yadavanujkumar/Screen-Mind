# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme_secure_password
DATABASE_URL=postgresql://screenmind:changeme_secure_password@localhost:5432/screenmind

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=changeme_redis_password
REDIS_URL=redis://:changeme_redis_password@localhost:6379/0

# ─── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
LLM_PROVIDER=openai

# Alternatively, use Ollama locally
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ─── Service URLs (for local development) ─────────────────────────────────────
API_GATEWAY_URL=http://localhost:8000
SCREEN_CAPTURE_URL=http://localhost:8002
VISION_URL=http://localhost:8003
STATE_BUILDER_URL=http://localhost:8004
LLM_REASONING_URL=http://localhost:8005
TASK_PLANNER_URL=http://localhost:8006
ACTION_EXECUTION_URL=http://localhost:8007
MEMORY_URL=http://localhost:8008
VERIFICATION_URL=http://localhost:8009
OBSERVABILITY_URL=http://localhost:8010
EXPLAINABILITY_URL=http://localhost:8011
TASK_QUEUE_URL=http://localhost:8012
CONVERSATION_URL=http://localhost:8013
SLACK_ADAPTER_URL=http://localhost:8014

# ─── Slack Remote Chat ─────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
AUTO_EXECUTE_DIRECTIONS=true

# ─── Security ─────────────────────────────────────────────────────────────────
SAFE_MODE=false
BLOCK_DANGEROUS_KEYS=true

# ─── Monitoring ───────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=changeme_grafana_password

# ─── Elasticsearch ────────────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200

# ─── OpenTelemetry ────────────────────────────────────────────────────────────
JAEGER_HOST=localhost
JAEGER_PORT=6831

# ─── Faiss ────────────────────────────────────────────────────────────────────
FAISS_INDEX_PATH=/data/faiss.index
